# Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
# telegram_id адміна — вмикає /stats_admin* команди (і їх admin-scope меню)
ADMIN_TELEGRAM_ID=

# Meta Marketing API (read-only) — для /stats_admin_ads* команд.
# Кампанії створюються в окремому repo (wordsnap-threads-bot); тут лише звіти.
META_ADS_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=
META_ADS_API_VERSION=v23.0

# OpenAI
OPENAI_API_KEY=your_openai_api_key

# Unsplash
UNSPLASH_ACCESS_KEY=your_unsplash_access_key

# Database (Supabase PostgreSQL)
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/dbname

# WayForPay
WAYFORPAY_MERCHANT_LOGIN=your_merchant_login
WAYFORPAY_MERCHANT_SECRET=your_merchant_secret_key
WAYFORPAY_MERCHANT_DOMAIN=your-domain.com
WAYFORPAY_RETURN_URL=https://your-domain.com/payment/return
# serviceUrl — куди WayForPay шле callback про оплату (треба для recurring charges)
WAYFORPAY_WEBHOOK_URL=https://your-domain.com/api/wayforpay/callback

# Sentry (помилки бекенду + фронту)
SENTRY_DSN=
# опц. теги для Sentry-релізів
ENV=production
RELEASE=

# PostHog (EU instance) — серверні події
POSTHOG_API_KEY=phc_xxx
POSTHOG_HOST=https://eu.posthog.com
POSTHOG_PROJECT_ID=
# personal API key — потрібен лише для scripts/setup_posthog_dashboard.py
POSTHOG_PERSONAL_API_KEY=

# Server
PORT=8000
